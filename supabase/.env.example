# Copy to `supabase/.env` (gitignored). Never commit real keys.

# --- Resend (`send-support-email`) ---
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL="Prolance <noreply@verified-domain.com>"
# SUPPORT_INBOX_EMAIL=support@yourdomain.com

# --- iyzico sandbox (Edge: `iyzico-init-checkout`, `iyzico-checkout-callback`) ---
# Dashboard: https://sandbox-merchant.iyzipay.com — API & Güvenlik keys (sandbox- prefix).
# Docs: https://docs.iyzico.com/en/getting-started/preliminaries/live-vs-sandbox
#
# IYZICO_API_KEY=sandbox-xxxxxxxx
# IYZICO_SECRET_KEY=sandbox-xxxxxxxx
# IYZICO_URI=https://sandbox-api.iyzipay.com
#
# Cep POS (ayrı ürün; standart Checkout Form için zorunlu değil — ileride kullanılabilir):
# IYZICO_CEP_POS_API_KEY=
# IYZICO_CEP_POS_SECRET_KEY=
